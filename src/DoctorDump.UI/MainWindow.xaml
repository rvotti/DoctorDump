<Window x:Class="DoctorDump.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DoctorDump" Height="720" Width="1120" MinHeight="560" MinWidth="860"
        Background="#F7F8FA">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="DoctorDump" FontSize="26" FontWeight="SemiBold" Foreground="#111827" />
                <TextBlock Text="Capture Windows process dumps and prepare developer-friendly reports." Foreground="#4B5563" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                <Button Content="Refresh" Width="96" Height="34" Margin="8,0,0,0" Click="Refresh_Click" />
                <Button Content="Capture" Width="104" Height="34" Margin="8,0,0,0" Click="Capture_Click" />
                <Button Content="Monitor Crash" Width="128" Height="34" Margin="8,0,0,0" Click="MonitorCrash_Click" />
                <Button Content="Analyze Dump" Width="124" Height="34" Margin="8,0,0,0" Click="AnalyzeExistingDump_Click" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="Processes" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBox x:Name="SearchBox" DockPanel.Dock="Right" Width="260" Height="30" Margin="12,0,0,0"
                                 TextChanged="SearchBox_TextChanged" VerticalContentAlignment="Center" />
                    </DockPanel>

                    <DataGrid x:Name="ProcessGrid" Grid.Row="1" ItemsSource="{Binding FilteredProcesses}"
                              AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="80" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="220" />
                            <DataGridTextColumn Header="Architecture" Binding="{Binding Architecture}" Width="120" />
                            <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Dump History" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,10" />

                    <ListBox x:Name="HistoryList" Grid.Row="1" ItemsSource="{Binding DumpHistory}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,6">
                                    <TextBlock Text="{Binding ProcessName}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding CapturedAtUtc}" Foreground="#4B5563" FontSize="12" />
                                    <TextBlock Text="{Binding DumpFilePath}" Foreground="#6B7280" FontSize="12" TextWrapping="Wrap" />
                                    <WrapPanel Margin="0,8,0,0">
                                        <Button Content="Open Report" Width="96" Height="28" Margin="0,0,6,0" Click="OpenReport_Click" />
                                        <Button Content="Folder" Width="68" Height="28" Margin="0,0,6,0" Click="OpenFolder_Click" />
                                        <Button Content="Re-analyze" Width="86" Height="28" Margin="0,0,6,0" Click="ReAnalyze_Click" />
                                        <Button Content="Delete" Width="64" Height="28" Click="DeleteEntry_Click" />
                                    </WrapPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <StatusBar Grid.Row="2" Margin="0,14,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
